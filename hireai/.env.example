# ─── Core ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000
DB_PATH=server/data/hireai.db
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_AGENCY_NAME=HireAI Realty
BOOTSTRAP_ADMIN_ON_START=false
ALLOW_MOCK_DELIVERY=true
JWT_ACCESS_TTL=7d
LOG_LEVEL=info

# ─── AI Brain ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp / SMS (Twilio) ──────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1234567890

# ─── Email (Gmail SMTP) ───────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_PASSWORD=
SENDGRID_API_KEY=

# ─── Server Limits / Safety ───────────────────────────────
REQUEST_BODY_LIMIT=1mb
WEBHOOK_RATE_WINDOW_MS=900000
WEBHOOK_RATE_MAX=300
WIDGET_RATE_WINDOW_MS=60000
WIDGET_RATE_MAX=80
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=40
SANITIZE_WEBHOOK_PAYLOADS=true
WEBHOOK_PAYLOAD_MAX_CHARS=12000
BACKUP_DIR=server/backups

# ─── Google Calendar ──────────────────────────────────────
# Store credentials JSON in calendarConfig field in Settings
# Format: {"clientId":"...","clientSecret":"...","redirectUri":"http://localhost:3001/api/calendar/oauth/callback"}

# ─── Razorpay Billing ─────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Get webhook secret from: Dashboard → Webhooks → Add New Webhook
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Legacy ───────────────────────────────────────────────
AGENCY_ID=agency_001
