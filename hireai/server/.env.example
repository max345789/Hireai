# ─── Core ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# ─── AI Brain ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_MODEL_CHAIN=claude,openai,gemini
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# ─── WhatsApp / SMS (Twilio) ──────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+1234567890
TWILIO_SMS_NUMBER=+1234567890

# ─── Email (Gmail SMTP) ───────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Google Calendar ──────────────────────────────────────
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URIs:
#   Dev:  http://localhost:3001/api/calendar/oauth/callback
#   Prod: https://hireai-3sd4.onrender.com/api/calendar/oauth/callback
# After adding these vars, click "Connect Google Calendar" in Settings — OAuth saves tokens automatically.
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# ─── Meta (Instagram DMs + Facebook Messenger) ────────────
# 1. Create a Meta App at https://developers.facebook.com/
# 2. Add "Messenger" and "Instagram" products to your app
# 3. Generate a Page Access Token with pages_messaging permission
# 4. In Webhooks setup, set:
#      Callback URL  : https://your-domain.com/api/webhook/meta
#      Verify Token  : same value as META_VERIFY_TOKEN below
#      Subscriptions : messages, messaging_postbacks
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=my-secret-verify-token-change-this
# Optional: App Secret for payload signature verification
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Razorpay Billing ─────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_key_secret
# Get webhook secret from: Dashboard → Webhooks → Add New Webhook
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
